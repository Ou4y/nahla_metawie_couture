<section class="nc-section">
  <div class="nc-container">
    <span class="nc-kicker">Atelier Notice</span>
    <h1 class="display-6">Something went wrong</h1>
    <p class="nc-muted">Please try again later.</p>
    <% if (error && error.message) { %>
      <pre class="bg-light p-3 rounded"><%= error.message %></pre>
    <% } %>
  </div>
</section>
