<section class="nc-section">
  <div class="nc-container">
    <div class="nc-page-header reveal">
      <span class="nc-kicker">Contact</span>
      <h1 class="display-5">Private inquiries and couture appointments</h1>
      <p class="nc-subtitle">Reach out for bookings, press, or bespoke requests.</p>
    </div>

    <div class="row g-5">
      <div class="col-lg-5 reveal">
        <div class="nc-card">
          <span class="nc-kicker">Atelier</span>
          <h2 class="h4">Nahla Couture</h2>
          <p class="mb-3">Rue de l'Atelier, Riyadh</p>
          <p class="mb-1">atelier@nahla-couture.com</p>
          <p class="mb-3">+966 555 000 000</p>
          <div class="nc-card">
            <span class="nc-kicker">Hours</span>
            <p class="mb-1">Mon-Sat, 10:00 - 19:00</p>
            <p class="mb-0">By appointment only</p>
          </div>
        </div>
      </div>
      <div class="col-lg-7 reveal" style="--delay: 0.1s;">
        <form class="nc-card">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label" for="name">Name</label>
              <input class="form-control" id="name" name="name" type="text" />
            </div>
            <div class="col-md-6">
              <label class="form-label" for="email">Email</label>
              <input class="form-control" id="email" name="email" type="email" />
            </div>
            <div class="col-12">
              <label class="form-label" for="subject">Subject</label>
              <input class="form-control" id="subject" name="subject" type="text" />
            </div>
            <div class="col-12">
              <label class="form-label" for="message">Message</label>
              <textarea class="form-control" id="message" name="message" rows="4"></textarea>
            </div>
          </div>
          <div class="mt-4">
            <button class="btn btn-primary" type="submit">Send inquiry</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>
