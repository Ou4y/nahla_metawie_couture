<section class="nc-section">
  <div class="nc-container">
    <div class="nc-page-header reveal">
      <span class="nc-kicker">Design System</span>
      <h1 class="display-5">Nahla Couture Atelier UI Kit</h1>
      <p class="nc-subtitle">
        A premium, appointment-first design system aligned to the couture
        experience. Components are styled for EJS, Bootstrap, and custom CSS.
      </p>
    </div>

    <div class="nc-section-head reveal" style="--delay: 0.1s;">
      <div>
        <span class="nc-kicker">Color Palette</span>
        <h2 class="h3">Signature neutrals and couture accents</h2>
      </div>
    </div>
    <div class="row g-3 mb-5">
      <div class="col-md-4 col-lg-2">
        <div class="nc-swatch" style="--swatch: #fff8f3;">
          <span>Warm Ivory</span>
          <strong>#FFF8F3</strong>
        </div>
      </div>
      <div class="col-md-4 col-lg-2">
        <div class="nc-swatch nc-swatch--dark" style="--swatch: #151515;">
          <span>Couture Charcoal</span>
          <strong>#151515</strong>
        </div>
      </div>
      <div class="col-md-4 col-lg-2">
        <div class="nc-swatch" style="--swatch: #f4b8b0;">
          <span>Soft Blush</span>
          <strong>#F4B8B0</strong>
        </div>
      </div>
      <div class="col-md-4 col-lg-2">
        <div class="nc-swatch" style="--swatch: #c8a46a;">
          <span>Champagne Gold</span>
          <strong>#C8A46A</strong>
        </div>
      </div>
      <div class="col-md-4 col-lg-2">
        <div class="nc-swatch" style="--swatch: #b89f96;">
          <span>Soft Taupe</span>
          <strong>#B89F96</strong>
        </div>
      </div>
      <div class="col-md-4 col-lg-2">
        <div class="nc-swatch nc-swatch--dark" style="--swatch: #0d0d0d;">
          <span>Espresso Black</span>
          <strong>#0D0D0D</strong>
        </div>
      </div>
    </div>

    <div class="row g-5 mb-5">
      <div class="col-lg-6 reveal" style="--delay: 0.15s;">
        <span class="nc-kicker">Typography</span>
        <h2 class="display-6">Playful serif drama with refined body copy</h2>
        <p>
          Use Cormorant Garamond for couture headlines, paired with Montserrat
          for clean editorial body text. Keep copy succinct and appointment
          focused.
        </p>
        <p class="nc-subtitle">Sample paragraph for body styling.</p>
      </div>
      <div class="col-lg-6 reveal" style="--delay: 0.2s;">
        <div class="nc-card">
          <div class="nc-kicker">Headings</div>
          <h1 class="display-6">Display Heading</h1>
          <h2 class="h3">Section Heading</h2>
          <h3 class="h5">Card Heading</h3>
          <div class="nc-kicker">Body</div>
          <p class="mb-0">
            Soft, modern, feminine. Keep paragraphs to two or three lines for
            an editorial rhythm.
          </p>
        </div>
      </div>
    </div>

    <div class="row g-4 mb-5">
      <div class="col-lg-6 reveal" style="--delay: 0.25s;">
        <span class="nc-kicker">Buttons</span>
        <div class="d-flex flex-wrap gap-3">
          <button class="btn btn-primary">Book Appointment</button>
          <button class="btn btn-outline-primary">Explore Collection</button>
          <button class="btn btn-secondary">Send Inquiry</button>
          <button class="btn btn-outline-secondary">Download Lookbook</button>
        </div>
      </div>
      <div class="col-lg-6 reveal" style="--delay: 0.3s;">
        <span class="nc-kicker">Inputs</span>
        <div class="nc-card">
          <div class="mb-3">
            <label class="form-label" for="ds-name">Full Name</label>
            <input class="form-control" id="ds-name" type="text" placeholder="Client name" />
          </div>
          <div class="mb-0">
            <label class="form-label" for="ds-type">Reservation Type</label>
            <select class="form-select" id="ds-type">
              <option>Bridal Couture</option>
              <option>Evening Couture</option>
            </select>
          </div>
        </div>
      </div>
    </div>

    <div class="row g-4 mb-5">
      <div class="col-lg-6 reveal" style="--delay: 0.35s;">
        <span class="nc-kicker">Cards</span>
        <div class="nc-card">
          <div class="nc-card-title">Atelier Consultation</div>
          <p class="nc-card-note">
            One-on-one design consultation, fabric review, and silhouette
            selection.
          </p>
        </div>
      </div>
      <div class="col-lg-6 reveal" style="--delay: 0.4s;">
        <span class="nc-kicker">Gallery Card</span>
        <div class="nc-card">
          <div class="nc-gallery-card"></div>
          <div class="mt-3">Rose Atelier</div>
        </div>
      </div>
    </div>

    <div class="row g-4 mb-5">
      <div class="col-lg-6 reveal" style="--delay: 0.45s;">
        <span class="nc-kicker">Navbar Preview</span>
        <div class="nc-preview-bar">
          <span class="nc-preview-logo">Nahla Couture</span>
          <span>Collections</span>
          <span>Gallery</span>
          <span>Atelier</span>
          <button class="btn btn-primary btn-sm">Appointment</button>
        </div>
      </div>
      <div class="col-lg-6 reveal" style="--delay: 0.5s;">
        <span class="nc-kicker">Footer Preview</span>
        <div class="nc-preview-footer">
          <div>
            <strong>Private Couture Atelier</strong>
            <p class="mb-0">By appointment only</p>
          </div>
          <div>
            <p class="mb-0">atelier@nahla-couture.com</p>
            <p class="mb-0">+966 555 000 000</p>
          </div>
        </div>
      </div>
    </div>

    <div class="row g-4 mb-5">
      <div class="col-lg-7 reveal" style="--delay: 0.55s;">
        <span class="nc-kicker">Appointment Form</span>
        <div class="nc-card">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label" for="ds-full">Full Name</label>
              <input class="form-control" id="ds-full" type="text" />
            </div>
            <div class="col-md-6">
              <label class="form-label" for="ds-phone">Phone</label>
              <input class="form-control" id="ds-phone" type="tel" />
            </div>
            <div class="col-md-6">
              <label class="form-label" for="ds-date">Preferred Date</label>
              <input class="form-control" id="ds-date" type="date" />
            </div>
            <div class="col-md-6">
              <label class="form-label" for="ds-time">Preferred Time</label>
              <input class="form-control" id="ds-time" type="time" />
            </div>
          </div>
        </div>
      </div>
      <div class="col-lg-5 reveal" style="--delay: 0.6s;">
        <span class="nc-kicker">WhatsApp Button</span>
        <div class="nc-card d-flex align-items-center gap-3">
          <span class="nc-whatsapp-preview">WA</span>
          <div>
            <div class="fw-semibold">WhatsApp Concierge</div>
            <div class="nc-card-note">Floating button for quick inquiries.</div>
          </div>
        </div>
      </div>
    </div>

    <div class="row g-4 mb-5">
      <div class="col-lg-6 reveal" style="--delay: 0.65s;">
        <span class="nc-kicker">Admin Components</span>
        <div class="nc-admin-card">
          <div class="d-flex justify-content-between">
            <div>
              <div class="nc-kicker">Pending</div>
              <div class="display-6">12</div>
            </div>
            <div>
              <div class="nc-kicker">Today</div>
              <div class="display-6">4</div>
            </div>
          </div>
        </div>
      </div>
      <div class="col-lg-6 reveal" style="--delay: 0.7s;">
        <span class="nc-kicker">Admin Table</span>
        <div class="table-responsive">
          <table class="table nc-table">
            <thead>
              <tr>
                <th>Client</th>
                <th>Date</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Client Name</td>
                <td>12 May</td>
                <td>Pending</td>
              </tr>
              <tr>
                <td>Client Name</td>
                <td>14 May</td>
                <td>Confirmed</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <div class="nc-section-head reveal" style="--delay: 0.75s;">
      <div>
        <span class="nc-kicker">Responsive Frames</span>
        <h2 class="h3">Desktop, tablet, and mobile breakpoints</h2>
      </div>
    </div>
    <div class="nc-frame-group mb-4">
      <div class="nc-frame" data-label="Desktop 1440" style="--frame-width: 1440px;">
        <div class="nc-frame-inner"></div>
      </div>
      <div class="nc-frame" data-label="Tablet 768" style="--frame-width: 768px;">
        <div class="nc-frame-inner"></div>
      </div>
      <div class="nc-frame" data-label="Mobile 390" style="--frame-width: 390px;">
        <div class="nc-frame-inner"></div>
      </div>
    </div>
  </div>
</section>
